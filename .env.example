# InterFinOps Environment Configuration
# Copy to .env and fill in real values. NEVER commit .env to version control.

# -------------------------------------------------------
# PostgreSQL
# -------------------------------------------------------
POSTGRES_USER=interfinops
POSTGRES_PASSWORD=change_me_to_a_strong_password
POSTGRES_DB=interfinops

# -------------------------------------------------------
# Database URL (used by backend)
# In Docker Compose this is constructed automatically; set manually for external DB.
# -------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://interfinops:change_me_to_a_strong_password@postgres:5432/interfinops

# -------------------------------------------------------
# Application secrets
# -------------------------------------------------------
SECRET_KEY=generate-a-64-char-random-hex-string-here
JWT_SECRET_KEY=generate-another-64-char-random-hex-string-here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# -------------------------------------------------------
# CORS / Security
# -------------------------------------------------------
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
ALLOWED_HOSTS=localhost,127.0.0.1

# -------------------------------------------------------
# Domain (production)
# -------------------------------------------------------
DOMAIN_NAME=example.com

# -------------------------------------------------------
# Environment
# -------------------------------------------------------
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=info
